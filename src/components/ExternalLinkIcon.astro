---
// Small "arrow out of a box" indicator for links that leave the site / open
// externally. Sized in `em` so it scales with the link's font size. Pair with
// target="_blank" rel="noopener noreferrer". In-site navigation should use a
// plain → arrow instead.
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="external-link-icon inline-block w-[0.85em] h-[0.85em] ml-1 align-[-0.1em]"
  aria-hidden="true"
>
  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
  <polyline points="15 3 21 3 21 9" />
  <line x1="10" y1="14" x2="21" y2="3" />
</svg>
