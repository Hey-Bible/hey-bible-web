---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FeatureLightbox from '../components/FeatureLightbox.astro';
import AppStoreButtons from '../components/AppStoreButtons.astro';

const developerFeatures = [
  {
    icon: '🤖',
    title: 'Agent Skill',
    description: 'Install the hey-bible skill from ClawHub and your AI agent can quote Scripture instantly.',
  },
  {
    icon: '🔌',
    title: 'MCP Server',
    description: 'A Model Context Protocol server for Claude Desktop and every MCP-native client.',
  },
  {
    icon: '⌨️',
    title: 'CLI',
    description: 'Look up verses from your terminal or automation, with --json output built for agents.',
  },
  {
    icon: '🌐',
    title: 'API & SDK',
    description: 'A typed TypeScript SDK and a REST API behind it all — the gateway for AI agents.',
  },
];

const features = [
  {
    icon: '🔍',
    title: 'Search & Favorites',
    description: 'Search any verse and save your favorites for quick access.',
    screenshot: '/img/screenshots/2-search.webp',
  },
  {
    icon: '📝',
    title: 'Personal Notes',
    description: 'Add your own notes to any verse for deeper study.',
    screenshot: '/img/screenshots/4-notes.webp',
  },
  {
    icon: '💬',
    title: 'AI Chat',
    description: 'Ask questions about scripture and get thoughtful answers.',
    screenshot: '/img/screenshots/5-chats.webp',
  },
  {
    icon: '🎨',
    title: 'Verse Art',
    description: 'Create beautiful, shareable images of your favorite verses.',
    screenshot: '/img/screenshots/6-images.webp',
  },
  {
    icon: '🔗',
    title: 'Sharing',
    description: 'Share verses and art with friends and family.',
    screenshot: '/img/screenshots/7-image.webp',
  },
  {
    icon: '📚',
    title: 'Multiple Translations',
    description: 'CSB, NLT, NASB, NKJV, KJV, WEB and more coming soon!',
    screenshot: '/img/screenshots/10-translations.png',
  },
  {
    icon: '📱',
    title: 'iOS Widget',
    description: 'Get a daily verse right on your home screen.',
    screenshot: '/img/screenshots/9-widget.webp',
  },
];
---

<BaseLayout
  title="Features | Hey Bible"
  description="Explore all the features of Hey Bible — search, favorites, notes, AI chat, widgets, verse art, and sharing."
>
  <div class="flex flex-col items-center pt-4 pb-4">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-2 px-4">Everything You Need to Study Scripture</h1>

    <div class="w-full mb-6 overflow-x-scroll" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">
      <div class="flex flex-row gap-6 px-4 py-4 items-stretch w-max">
        {features.map(f => (
          <FeatureCard
            icon={f.icon}
            title={f.title}
            description={f.description}
            screenshot={f.screenshot}
          />
        ))}
      </div>
    </div>

    <FeatureLightbox />

    <p class="text-lg text-center max-w-[600px] mb-10 opacity-80 px-4">
      Hey Bible packs powerful tools into a simple, beautiful app.
    </p>

    <!-- For developers & AI agents -->
    <div class="w-full max-w-[900px] px-4 mb-10">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-2 text-center">For Developers &amp; AI Agents</h2>
      <p class="text-base text-center mb-6 opacity-80">
        Hey Bible is also the one-stop gateway for giving AI agents access to the Bible.
      </p>
      <div class="flex flex-row flex-wrap gap-6 justify-center items-stretch">
        {developerFeatures.map(f => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/agents" class="login-button text-base">Explore the agent gateway →</a>
      </div>
    </div>

    <div class="text-center">
      <h2 class="text-2xl font-extrabold mb-4">Ready to get started?</h2>
      <AppStoreButtons size="large" />
    </div>
  </div>
</BaseLayout>
