---
interface Props {
  size?: 'default' | 'large';
}

const { size = 'default' } = Astro.props;
const sizeClass = size === 'large' ? 'app-store-icon-large' : '';
---

<div class="flex flex-col gap-3 items-center mt-2">
  <a
    href="https://apps.apple.com/us/app/hey-bible/id6474075530"
    target="_blank"
    rel="noopener noreferrer"
  >
    <img
      class={`app-store-icon ${sizeClass}`}
      src="/img/app-store.svg"
      alt="Download on the App Store"
    />
  </a>
  <a
    href="https://play.google.com/store/apps/details?id=com.workingdevshero.heybible"
    target="_blank"
    rel="noopener noreferrer"
  >
    <img
      class={`app-store-icon ${sizeClass}`}
      src="/img/play-store.svg"
      alt="Get it on Google Play"
    />
  </a>
</div>
