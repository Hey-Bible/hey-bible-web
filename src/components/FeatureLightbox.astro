---
---

<div id="feature-lightbox" class="lightbox">
  <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
  <button class="lightbox-nav lightbox-prev" aria-label="Previous feature">&larr;</button>
  <div class="lightbox-content" style="width: 320px; max-width: 90vw;">
    <div
      id="feature-lightbox-card"
      class="rounded-2xl p-6 w-full flex flex-col"
      style={`background: var(--color-retro-surface-card); min-height: 200px;`}
    >
      <h3 id="feature-lightbox-title" class="text-xl font-extrabold mb-2" style={`color: var(--color-retro-text);`}></h3>
      <p id="feature-lightbox-desc" class="text-sm leading-relaxed opacity-80 mb-4" style={`color: var(--color-retro-text);`}></p>
      <img id="feature-lightbox-img" src="" alt="" class="rounded-xl mx-auto flex-1 object-contain" style="box-shadow: 0 4px 20px rgba(0,0,0,0.1); max-height: 60vh; width: 100%;" />
    </div>
  </div>
  <button class="lightbox-nav lightbox-next" aria-label="Next feature">&rarr;</button>
</div>

<script>
  function initFeatureLightbox() {
    const lightbox = document.getElementById('feature-lightbox');
    const titleEl = document.getElementById('feature-lightbox-title');
    const descEl = document.getElementById('feature-lightbox-desc');
    const imgEl = document.getElementById('feature-lightbox-img') as HTMLImageElement;
    const closeBtn = lightbox?.querySelector('.lightbox-close');
    const prevBtn = lightbox?.querySelector('.lightbox-prev');
    const nextBtn = lightbox?.querySelector('.lightbox-next');
    const cards = document.querySelectorAll('.feature-card');

    if (!lightbox || !titleEl || !descEl || !imgEl || !cards.length) return;

    interface FeatureData {
      title: string;
      description: string;
      screenshot: string;
    }

    const features: FeatureData[] = Array.from(cards).map(card => ({
      title: card.getAttribute('data-title') || '',
      description: card.getAttribute('data-description') || '',
      screenshot: card.getAttribute('data-screenshot') || '',
    }));

    let current = 0;

    function show(index: number) {
      if (index < 0) index = features.length - 1;
      if (index >= features.length) index = 0;
      current = index;
      const f = features[current];
      titleEl!.textContent = f.title;
      descEl!.textContent = f.description;
      if (f.screenshot) {
        imgEl!.src = f.screenshot;
        imgEl!.alt = `${f.title} screenshot`;
        imgEl!.style.display = '';
      } else {
        imgEl!.style.display = 'none';
      }
    }

    function open(index: number) {
      show(index);
      lightbox!.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox!.classList.remove('active');
      document.body.style.overflow = '';
    }

    cards.forEach((card, i) => {
      (card as HTMLElement).style.cursor = 'pointer';
      card.addEventListener('click', () => open(i));
    });

    closeBtn!.addEventListener('click', close);
    prevBtn!.addEventListener('click', (e) => { e.stopPropagation(); show(current - 1); });
    nextBtn!.addEventListener('click', (e) => { e.stopPropagation(); show(current + 1); });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox!.classList.contains('active')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    let touchStartX = 0;
    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e) => {
      const diff = touchStartX - (e as TouchEvent).changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        show(diff > 0 ? current + 1 : current - 1);
      }
    }, { passive: true });
  }

  initFeatureLightbox();
  document.addEventListener('astro:after-swap', initFeatureLightbox);
</script>
