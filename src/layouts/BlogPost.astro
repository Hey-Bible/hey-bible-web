---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  heroImage?: string;
  tags: string[];
}

const { title, description, pubDate, updatedDate, author, heroImage, tags } = Astro.props;
---

<BaseLayout title={`${title} | Hey Bible Blog`} description={description} image={heroImage}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <div class="rounded-2xl overflow-hidden" style={`background: var(--color-retro-surface-card); box-shadow: 0 4px 24px rgba(0,0,0,0.08); border: 1px solid var(--color-retro-secondary);`}>
      <div class="p-6 md:p-10">
        {heroImage && (
          <img
            src={heroImage}
            alt={title}
            class="w-full rounded-2xl mb-8"
            style="box-shadow: 0 4px 20px rgba(0,0,0,0.1);"
          />
        )}
        <div class="mb-8">
          {tags.length > 0 && (
            <div class="flex gap-2 mb-3">
              {tags.map(tag => (
                <a
                  href={`/blog/tag/${tag.toLowerCase()}`}
                  class="text-xs font-bold px-3 py-1 rounded-full no-underline"
                  style={`background: var(--color-retro-primary); color: #ffffff;`}
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
          <h1 class="text-3xl md:text-4xl font-extrabold text-left mb-2">{title}</h1>
          <p class="text-sm opacity-60">
            By {author} &middot; <FormattedDate date={pubDate} />
            {updatedDate && (
              <span> &middot; Updated <FormattedDate date={updatedDate} /></span>
            )}
          </p>
        </div>
        <div class="blog-prose">
          <slot />
        </div>
        <div class="mt-12 pt-6" style={`border-top: 1px solid var(--color-retro-secondary);`}>
          <a href="/blog" class="glow-hover font-bold">&larr; Back to Blog</a>
        </div>
      </div>
    </div>
  </article>

  <script>
    const COPY_ICON =
      '<svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path stroke-linecap="round" stroke-linejoin="round" d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg>';
    const CHECK_ICON =
      '<svg class="check-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>';

    // Give every code block in the post a copy button. The button lives in a
    // relative wrapper (a sibling of <pre>) so it stays pinned to the top-right
    // even when the code scrolls horizontally.
    function initCopyButtons() {
      document
        .querySelectorAll<HTMLPreElement>(".blog-prose pre")
        .forEach((pre) => {
          if (pre.dataset.copyReady) return;
          pre.dataset.copyReady = "true";

          const wrapper = document.createElement("div");
          wrapper.className = "code-block";
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "copy-btn";
          btn.setAttribute("aria-label", "Copy");
          btn.setAttribute("title", "Copy");
          btn.innerHTML = COPY_ICON + CHECK_ICON;
          wrapper.appendChild(btn);

          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code") ?? pre;
            const text = code.textContent ?? "";
            try {
              await navigator.clipboard.writeText(text);
              btn.classList.add("copied");
              btn.setAttribute("aria-label", "Copied");
              window.setTimeout(() => {
                btn.classList.remove("copied");
                btn.setAttribute("aria-label", "Copy");
              }, 1500);
            } catch {
              /* clipboard unavailable (e.g. insecure context) — no-op */
            }
          });
        });
    }

    initCopyButtons();
    document.addEventListener("astro:after-swap", initCopyButtons);
  </script>
</BaseLayout>
