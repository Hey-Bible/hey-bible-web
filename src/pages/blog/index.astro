---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))];
---

<BaseLayout
  title="Blog | Hey Bible"
  description="News, updates, and tutorials from the Hey Bible team."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-2">Hey Bible Blog</h1>
    <p class="text-center text-lg opacity-70 mb-8">News, updates, and tutorials from our team.</p>

    {allTags.length > 0 && (
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        <a
          href="/blog"
          class="text-sm font-bold px-4 py-1.5 rounded-full no-underline transition-all duration-200"
          style={`background: var(--color-retro-primary); color: #ffffff;`}
        >
          All
        </a>
        {allTags.map(tag => (
          <a
            href={`/blog/tag/${tag.toLowerCase()}`}
            class="text-sm font-bold px-4 py-1.5 rounded-full no-underline transition-all duration-200 hover:opacity-80"
            style={`background: var(--color-retro-surface-card); color: var(--color-retro-text); border: 1px solid var(--color-retro-secondary);`}
          >
            {tag}
          </a>
        ))}
      </div>
    )}

    <div class="grid grid-cols-1 gap-6 max-w-2xl mx-auto w-full">
      {allPosts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </div>

    {allPosts.length === 0 && (
      <p class="text-center text-lg opacity-60 mt-12">No posts yet. Check back soon!</p>
    )}
  </div>
</BaseLayout>
